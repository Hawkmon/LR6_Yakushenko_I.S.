# Блок команды запуска проекта в Replit.
# Django запускается на 0.0.0.0:3000, чтобы веб-просмотр Replit мог открыть приложение.
run = ["python", "manage.py", "runserver", "0.0.0.0:3000"]

# Блок точки входа.
# Replit использует manage.py как основной файл Django-проекта.
entrypoint = "manage.py"

# Блок версии runtime.
# Модуль python-3.10 задает интерпретатор Python для среды Replit.
modules = ["python-3.10:v18-20230807-322e88b"]

# Блок скрытых служебных папок.
# .pythonlibs содержит установленные зависимости и не должен отображаться как исходный код проекта.
hidden = [".pythonlibs"]

[nix]
# Блок канала Nix.
# stable-24_05 фиксирует набор системных пакетов для воспроизводимого окружения.
channel = "stable-24_05"

[unitTest]
# Блок настройки языка тестирования.
# Replit будет запускать тесты как Python-тесты.
language = "python3"

[deployment]
# Блок команды деплоя.
# Та же команда поднимает Django-приложение при публикации проекта.
run = ["python", "manage.py", "runserver", "0.0.0.0:3000"]
deploymentTarget = "gce"

[[ports]]
# Блок публикации основного web-порта.
# Локальный порт 3000 отображается наружу как HTTP-порт 80.
localPort = 3000
externalPort = 80

[[ports]]
# Блок дополнительного порта приложения.
# Порт 8000 оставлен для совместимости с Docker-запуском Django.
localPort = 8000
externalPort = 8000

[agent]
# Блок режима помощника Replit.
# expertMode включает расширенный режим работы встроенного агента.
expertMode = true
